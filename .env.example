# Copy to .env.local and fill in. Never commit real keys.
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/onceupon
JWT_SECRET=change-me-to-a-long-random-string
ADMIN_EMAILS=owner@example.com
ANTHROPIC_API_KEY=sk-ant-...
# Server-side fal.ai key. Create one at https://fal.ai/dashboard/keys
FAL_KEY=
# Fallback image API key name supported by the app:
# IMAGE_API_KEY=
# Optional model overrides:
# FAL_TEXT_TO_IMAGE_MODEL=fal-ai/nano-banana
# FAL_IMAGE_EDIT_MODEL=fal-ai/nano-banana/edit
# FAL_UPSCALE_MODEL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
BLOB_READ_WRITE_TOKEN=
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
GELATO_ENABLED=false
GELATO_API_KEY=
GELATO_ORDER_TYPE=draft
GELATO_SOFTCOVER_UID=
GELATO_HARDCOVER_UID=
GELATO_WEBHOOK_SECRET=
# Required in production for /api/cron/sync-orders.
CRON_SECRET=
APP_URL=http://localhost:3000
# Email (Resend — https://resend.com). Required for gift card emails.
RESEND_API_KEY=re_...
EMAIL_FROM=Once Upon <noreply@yourdomain.com>
# Recommended in production for shared rate limiting across instances.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
